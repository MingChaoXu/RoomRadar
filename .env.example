APP_ENV=local
APP_NAME=hotel-spider
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/hotel_spider.db
PROVIDER_MODE=mock
AMAP_PROVIDER=mock
AMAP_MCP_COMMAND=npx
AMAP_MCP_ARGS=-y @amap/amap-maps-mcp-server
AMAP_MAPS_API_KEY=
AMAP_JS_API_KEY=
AMAP_MCP_TIMEOUT_SECONDS=20
AMAP_HOTEL_KEYWORD=酒店
PLAYWRIGHT_BROWSERS_PATH=
CTRIP_PROVIDER=mock
CTRIP_STORAGE_STATE_PATH=
CTRIP_HEADLESS=true
MEITUAN_PROVIDER=mock
MEITUAN_STORAGE_STATE_PATH=
MEITUAN_HEADLESS=true
